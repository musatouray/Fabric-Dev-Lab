/// Date dimension with calendar and fiscal breakdowns. Use FullDateAlternateKey in time intelligence filters and CalendarYear for yearly analysis.
table DimDate
	lineageTag: 2008242e-4713-4dc5-8a45-47fccc80f5bd
	sourceLineageTag: [dbo].[DimDate]
	dataCategory: Time

	/// Integer surrogate key in YYYYMMDD format. Used as FK in fact tables.
	column DateKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 1e2d9183-57a0-43f6-8cf9-d424c3b21a7a
		sourceLineageTag: DateKey
		isDefaultLabel
		summarizeBy: none
		sourceColumn: DateKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	/// Full calendar date value. Use this column in time intelligence functions (SAMEPERIODLASTYEAR, etc.).
