table 'Fact Metric Selector'
	lineageTag: 9db16ba9-37ff-4a5c-844d-0d004152a942

	/// Switch between Fact Orders, Fact Revenue and Fact Profit in visuals
	calculationGroup
		precedence: 11

		multipleOrEmptySelectionExpression = SELECTEDMEASURE()

		noSelectionExpression = SELECTEDMEASURE()

		/// Fact number of orders
		calculationItem Orders = [Fact Orders]

			formatStringDefinition = "#,0"

		/// Fact Revenue
		calculationItem Revenue = [Fact Revenue]

			formatStringDefinition = "$#,##0.00"

		/// Fact Profit
		calculationItem Profit = [Fact Profit]

			formatStringDefinition = "$#,##0.00"

	column Metric
		dataType: string
		lineageTag: c64cd8c0-3dfb-4dc2-9eb8-61396f0bf4b0

	partition 'Partition_Metric Selector' = calculationGroup

